    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "pretest": "npm run lint",
    "test": "jest --coverage",
    "test:ci": "cross-env CI=true npm test -- --runInBand",
    "test:unit": "jest --coverage=false --testPathPattern=tests/unit",
    "test:integration": "jest --coverage=false --testPathPattern=tests/integration",
    "test:e2e": "jest --coverage=false --testPathPattern=tests/e2e",
    "coverage": "jest --coverage && node ./scripts/coverage-check.js",
    "posttest": "node ./scripts/coverage-check.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "^55.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
